# ─────────────────────────────────────────────
# AI
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─────────────────────────────────────────────
# Economic Calendar
# ─────────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_api_key_here

# ─────────────────────────────────────────────
# Futures: TopstepX / ProjectX
# ─────────────────────────────────────────────
PROJECTX_USERNAME=your_topstepx_email
PROJECTX_API_KEY=your_projectx_api_key

# ─────────────────────────────────────────────
# Stocks: Questrade (optional, future)
# ─────────────────────────────────────────────
QUESTRADE_ACCESS_TOKEN=

# ─────────────────────────────────────────────
# Provider selection
# ─────────────────────────────────────────────

# Futures: "yahoo" (free, ~15 min delay) | "projectx" (real-time, paid)
FUTURES_PROVIDER=projectx

# Stocks: "yahoo" (free, ~15 min delay) | "finnhub" (real-time, free) | "questrade" (planned)
# Note: charts always use Yahoo Finance for historical OHLCV regardless of this setting
STOCKS_PROVIDER=finnhub

# ─────────────────────────────────────────────
# Auth (leave blank to disable login)
# ─────────────────────────────────────────────
APP_USERNAME=your_username
APP_PASSWORD=your_password

# ─────────────────────────────────────────────
# App settings
# ─────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
REFRESH_INTERVAL=60
